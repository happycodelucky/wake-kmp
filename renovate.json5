// Renovate configuration.
//
// Automates the "use the latest stable, web-search before bumping" policy
// (see CLAUDE.md §2 / §10): Renovate opens a PR when a dependency in
// gradle/libs.versions.toml (or a GitHub Action) has a newer stable
// release, and CI's full check gates the merge.
{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  packageRules: [
    {
      // Never EAP / RC / beta / alpha on main. Renovate's default versioning
      // already prefers stable, but Kotlin-ecosystem pre-releases use
      // suffixes it can misread — be explicit.
      matchManagers: ['gradle'],
      ignoreUnstable: true,
    },
    {
      // Kotlin is bounded above by SKIE's supported range ("if SKIE doesn't
      // yet support a Kotlin version, we wait"). A Kotlin bump must be a
      // deliberate, human-paired change with the SKIE pin — Renovate must
      // not propose it on its own. The prefix also covers the
      // kotlin-serialization plugin, which versions in lockstep with Kotlin.
      matchPackagePrefixes: ['org.jetbrains.kotlin'],
      enabled: false,
      description: 'Kotlin pin is SKIE-bound; bump manually together with the skie version.',
    },
    {
      // SKIE bumps are welcome — they're what eventually unlocks a Kotlin
      // bump. Label them so the paired manual Kotlin review is prompted.
      matchPackagePrefixes: ['co.touchlab.skie'],
      labels: ['skie', 'check-kotlin-pin'],
    },
  ],
}
